{
  "manifest_version": 3,
  "name": "Safe Browsing Buddy",
  "version": "1.0.0",
  "description": "Identify potentially suspicious websites and get practical safe-browsing tips — analysis runs locally in your browser.",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Safe Browsing Buddy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [],
  "offline_enabled": true
}
