{
  "manifest_version": 3,
  "name": "Safe Browsing Buddy",
  "version": "1.0.0",
  "description": "Analyze website URLs locally and promote safer browsing habits.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Safe Browsing Buddy"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
